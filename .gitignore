# Build directory (latexmk $out_dir)
build/

# LaTeX build artifacts
*.aux
*.log
*.out
*.bbl
*.blg
*.synctex.gz
*.fls
*.fdb_latexmk
*.toc

# Ignore stray PDFs (e.g. compiled output left in the root), but keep
# figure/table/brand assets that are intentionally version-controlled.
*.pdf
!figs/*.pdf
!tbls/*.pdf
!assets/*.pdf

# Local docs / design notes (not pushed)
docs/

# OS metadata
.DS_Store
